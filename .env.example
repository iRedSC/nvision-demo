# Host port exposed by Docker. Dokploy can route to the Home Assistant service
# on container port 8123 without changing this locally.
HA_PORT=8123

# Container timezone.
TZ=Etc/UTC

# Bundle URL loaded into /local/nvision/nvision.js.
# Pin this to a release/tag when you want the public demo to stop tracking main.
NVISION_BUNDLE_URL=https://raw.githubusercontent.com/iRedSC/nvision/main/dist/nvision.js
