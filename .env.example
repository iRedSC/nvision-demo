# Host port exposed by Docker. Dokploy can route to the Home Assistant service
# on container port 8123 without changing this locally.
HA_PORT=8123

# Container timezone.
TZ=Etc/UTC

# Demo auto-login landing page at /local/demo/
DEMO_USERNAME=demo
DEMO_PASSWORD=change-me
DEMO_DASHBOARD_PATH=/lovelace/nvision-demo
